# Copy to backend/.env for local dev. Do NOT commit the real .env.
# Local Docker Neo4j (matches docker-compose.yml):
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nebula-local-dev

# Production: point these at your Neo4j Aura instance instead, e.g.
# NEO4J_URI=neo4j+s://<dbid>.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=<aura-password>

FRONTEND_ORIGIN=http://localhost:5173

# Gemini for the LLM extractor / agents (AI Studio key). google-genai also reads
# this from your shell env, so it's optional here for local runs.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Production only (leave unset locally) --------------------------------------
# Auth (Cloud Run): require Firebase login, allow-list emails.
# REQUIRE_AUTH=true
# ALLOWED_EMAILS=yrnclndymn@gmail.com,andy@emergentstrategies.tech
# Durable jobs via Cloud Tasks (survive scale-to-zero):
# JOB_MODE=cloudtasks
# GCP_PROJECT=emergent-strategies
# CLOUD_TASKS_LOCATION=europe-west2
# SERVICE_URL=https://nebula-api-xxxx.run.app
# TASKS_SERVICE_ACCOUNT=nebula-tasks@emergent-strategies.iam.gserviceaccount.com
# Frontend build (Vite, prod): VITE_AUTH_ENABLED=true and the VITE_FIREBASE_* config
# (apiKey/authDomain/projectId/appId) from the Firebase console; VITE_API_BASE=/api.
